#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source dir
  source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SEALION_HOME="${SEALION_HOME:-$(cd "$(resolve_script_dir)/.." >/dev/null 2>&1 && pwd)}"
SEALION_VERSION="${SEALION_VERSION:-0.1.0-dev}"

print_help() {
  cat <<'HELP'
Sealion

global actions:
  sealion help
    show this help
  sealion version
    print the installed version

features:
  install the CLI from GitHub
  # curl -fsSL <github-install-url> | bash
  curl -fsSL https://raw.githubusercontent.com/ryangerardwilson/sealion/main/install.sh | bash

  create a new project directory
  # sealion new <project-name>
  sealion new demo

  initialize the current empty directory
  # sealion init
  mkdir demo && cd demo && sealion init

  run the local development stack
  # sealion run dev
  cd demo && sealion run dev
HELP
}

fail() {
  printf 'sealion: %s\n' "$*" >&2
  exit 1
}

require_template() {
  local template="$SEALION_HOME/templates/default"
  [ -d "$template" ] || fail "missing template: $template"
  printf '%s\n' "$template"
}

project_slug() {
  local input="$1"
  printf '%s' "$input" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9' '-' \
    | sed -e 's/^-*//' -e 's/-*$//' -e 's/--*/-/g'
}

escape_sed_replacement() {
  printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'
}

copy_template() {
  local target="$1"
  local name="$2"
  local slug="$3"
  local template name_escaped slug_escaped

  template="$(require_template)"
  mkdir -p "$target"
  cp -R "$template/." "$target/"

  name_escaped="$(escape_sed_replacement "$name")"
  slug_escaped="$(escape_sed_replacement "$slug")"

  while IFS= read -r -d '' file; do
    sed -i.bak \
      -e "s/__PROJECT_NAME__/$name_escaped/g" \
      -e "s/__PROJECT_SLUG__/$slug_escaped/g" \
      "$file"
    rm -f "$file.bak"
  done < <(find "$target" -type f -print0)
}

ensure_project_name() {
  local name="$1"
  case "$name" in
    ""|.*|*/*) fail "project name must be a simple directory name" ;;
  esac
  case "$name" in
    *[!A-Za-z0-9._-]*) fail "project name may contain only letters, numbers, dots, underscores, and dashes" ;;
  esac
}

command_new() {
  local name="${1:-}"
  local target slug
  [ -n "$name" ] || fail "usage: sealion new <project-name>"
  ensure_project_name "$name"
  target="$PWD/$name"
  [ ! -e "$target" ] || fail "$name already exists"
  slug="$(project_slug "$name")"
  [ -n "$slug" ] || slug="sealion-app"
  copy_template "$target" "$name" "$slug"
  printf 'created %s\n' "$target"
  printf 'next:\n'
  printf '  cd %s\n' "$name"
  printf '  sealion run dev\n'
}

command_init() {
  local name slug existing
  existing="$(find "$PWD" -mindepth 1 -maxdepth 1 -print -quit)"
  [ -z "$existing" ] || fail "sealion init requires an empty directory"
  name="$(basename "$PWD")"
  ensure_project_name "$name"
  slug="$(project_slug "$name")"
  [ -n "$slug" ] || slug="sealion-app"
  copy_template "$PWD" "$name" "$slug"
  printf 'initialized %s\n' "$PWD"
  printf 'next:\n'
  printf '  sealion run dev\n'
}

compose_command() {
  if docker compose version >/dev/null 2>&1; then
    printf 'docker compose'
    return
  fi
  if command -v docker-compose >/dev/null 2>&1; then
    printf 'docker-compose'
    return
  fi
  fail "Docker Compose is required for sealion run dev"
}

command_run_dev() {
  [ -f "$PWD/sealion.toml" ] || fail "run this inside a Sealion project"
  local compose port
  compose="$(compose_command)"
  port="${SEALION_HTTP_PORT:-8080}"
  printf 'starting Sealion dev stack\n'
  printf 'app: http://localhost:%s\n' "$port"
  printf 'demo login: admin@sealion.local / password\n'
  # shellcheck disable=SC2086
  $compose up --build
}

case "${1:-help}" in
  help|-h|--help)
    print_help
    ;;
  version)
    printf 'sealion %s\n' "$SEALION_VERSION"
    ;;
  new)
    shift
    command_new "${1:-}"
    ;;
  init)
    shift
    [ "$#" -eq 0 ] || fail "usage: sealion init"
    command_init
    ;;
  run)
    shift
    case "${1:-}" in
      dev)
        shift
        [ "$#" -eq 0 ] || fail "usage: sealion run dev"
        command_run_dev
        ;;
      *) fail "usage: sealion run dev" ;;
    esac
    ;;
  *)
    fail "unknown command: $1"
    ;;
esac
