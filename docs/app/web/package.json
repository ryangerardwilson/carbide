    "tailwind:build": "bun src/build-styles.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/cli": "4.3.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
