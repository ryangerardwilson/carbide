# Copy this file to `.env` only for local overrides.
#
# Docker Compose already provides safe local defaults from docker-compose.yml.
# Deployment secrets belong in shell env or CI secrets consumed by
# `deploy/prod.sh`, not in this file.
#
# CARBIDE_HTTP_PORT=18080
# APP_ENV=development
# PUBLIC_APP_NAME=Carbide Docs
# POSTGRES_PASSWORD=carbide
