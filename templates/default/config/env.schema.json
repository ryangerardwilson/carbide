{
  "$schema": "https://carbide.dev/schema/env.schema.json",
  "version": 1,
  "variables": [
    {
      "name": "CARBIDE_HTTP_PORT",
      "service": "frontend",
      "required": false,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "8080",
      "description": "Host port published by the frontend container."
    },
    {
      "name": "PUBLIC_URL",
      "service": "frontend",
      "required": true,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "http://localhost:8080",
      "description": "External app URL generated from the selected local port."
    },
    {
      "name": "PUBLIC_APP_NAME",
      "service": "frontend",
      "required": false,
      "secret": false,
      "browser_exposed": true,
      "framework_owned": false,
      "local_default": "__PROJECT_NAME__",
      "description": "Browser-safe display name for the generated web app."
    },
    {
      "name": "BACKEND_URL",
      "service": "frontend",
      "required": true,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "http://backend:8080",
      "description": "Private Compose URL used by the frontend proxy."
    },
    {
      "name": "APP_ENV",
      "service": "backend",
      "required": true,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": false,
      "local_default": "development",
      "description": "Application environment name."
    },
    {
      "name": "APP_PORT",
      "service": "backend",
      "required": true,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "8080",
      "description": "Internal backend container port."
    },
    {
      "name": "DATABASE_URL",
      "service": "backend",
      "required": true,
      "secret": true,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "postgres://carbide:carbide@db:5432/carbide",
      "description": "Backend Postgres connection string."
    },
    {
      "name": "POSTGRES_DB",
      "service": "db",
      "required": true,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "carbide",
      "description": "Local Postgres database name."
    },
    {
      "name": "POSTGRES_USER",
      "service": "db",
      "required": true,
      "secret": false,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "carbide",
      "description": "Local Postgres user."
    },
    {
      "name": "POSTGRES_PASSWORD",
      "service": "db",
      "required": true,
      "secret": true,
      "browser_exposed": false,
      "framework_owned": true,
      "local_default": "carbide",
      "description": "Local Postgres password. Replace in real deploy targets."
    }
  ]
}
